{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CutShon",
  "version": "0.1.0",
  "identifier": "com.cutshon.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CutShon",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
